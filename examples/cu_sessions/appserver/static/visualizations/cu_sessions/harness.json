{
  "label": "Agentic Usage — Session Board",
  "defaultSize": { "width": 1460, "height": 560 },
  "noDataMessage": "No active sessions",
  "dependencies": [],
  "fields": [
    { "name": "_numRows", "label": "Number of Sessions", "type": "slider", "min": 1, "max": 10, "step": 1, "default": 8 }
  ],
  "formatter": [
    { "name": "title", "label": "Title", "type": "text", "default": "Active Sessions" },
    { "name": "subtitle", "label": "Subtitle", "type": "text", "default": "live · 30m window" },
    { "name": "activeThresholdSec", "label": "Active Threshold (s)", "type": "text", "default": "120" },
    { "name": "ctxWarnPct", "label": "Ctx Warn %", "type": "text", "default": "60" },
    { "name": "ctxHighPct", "label": "Ctx High %", "type": "text", "default": "85" },
    { "name": "accentColor", "label": "Accent", "type": "color", "default": "#28b6a4" },
    { "name": "maxRows", "label": "Max Rows", "type": "text", "default": "50" },
    { "name": "theme", "label": "Theme", "type": "select", "options": ["dark", "light"], "default": "dark" }
  ],
